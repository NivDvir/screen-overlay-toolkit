+        private func mropeCosSin(positionIds: MLXArray) -> (MLXArray, MLXArray) {
+            // positionIds: [3, batch, seq]
+            let invFreqExpanded = _invFreqBox.value.reshaped(1, 1, -1, 1)  // [1, 1, dim/2, 1]
